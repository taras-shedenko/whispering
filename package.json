{
  "name": "whispering",
  "version": "1.0.0",
  "main": "app.js",
  "license": "MIT",
  "scripts": {
    "lint": "eslint src",
    "build": "tsc",
    "start": "nodemon -e ts,ejs --exec ts-node src/app.ts",
    "test": "jest --setupFiles dotenv/config",
    "test:coverage": "jest --setupFiles dotenv/config --coverage",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down --remove-orphans"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.1",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "body-parser": "^2.2.0",
    "dotenv": "^16.5.0",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "mongoose": "^8.14.1"
  }
}
